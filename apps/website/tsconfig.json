{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "noEmit": true,
    "outDir": "../../dist/out-tsc",
    "types": [
      "../../node_modules/@docusaurus/module-type-aliases",
      "../../node_modules/@docusaurus/theme-classic",
      "environment",
      "static-assets",
      "webpack-env"
    ]
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
