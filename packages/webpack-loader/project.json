{
  "name": "@griffel/webpack-loader",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/webpack-loader/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/webpack-loader"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/webpack-loader/dist"],
      "options": {
        "cwd": "packages/webpack-loader",
        "commands": ["tsc --build tsconfig.lib.json --pretty"],
        "parallel": false
      }
    }
  }
}
