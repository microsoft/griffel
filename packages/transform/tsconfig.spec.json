{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "typeRoots": ["../../node_modules", "../../node_modules/@types", "../../typings"],
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node", "vitest", "environment"]
  },
  "include": ["src/**/*.spec.mts", "src/**/*.test.mts", "src/**/*.d.mts"],
  "references": [{ "path": "./tsconfig.lib.json" }]
}
