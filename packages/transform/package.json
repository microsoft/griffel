{
  "name": "@griffel/transform",
  "version": "1.2.1",
  "types": "./index.d.mts",
  "description": "A package that performs build time transforms for Griffel",
  "files": [
    "*.js",
    "*.d.mts",
    "*.d.ts",
    "dist/"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/griffel"
  },
  "type": "module",
  "exports": {
    ".": {
      "@griffel/source": "./src/index.mts",
      "node": "./transform.js",
      "types": "./index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@griffel/react": "^1.6.0"
  },
  "dependencies": {
    "@griffel/core": "^1.20.1",
    "@linaria/shaker": "^3.0.0-beta.22",
    "debug": "^4.3.0",
    "magic-string": "^0.30.19",
    "oxc-parser": "^0.116.0",
    "oxc-walker": "^0.7.0"
  }
}
