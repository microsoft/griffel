{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "outDir": "./out-tsc/spec",
    "types": ["jest", "node", "environment", "static-assets"]
  },
  "include": [
    "__fixtures__/**/*/code.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.test.jsx",
    "**/*.spec.jsx",
    "**/*.d.ts",
    "jest.config.ts"
  ],
  "references": [{ "path": "./tsconfig.lib.json" }]
}
