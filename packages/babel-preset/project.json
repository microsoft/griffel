{
  "name": "@griffel/babel-preset",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/babel-preset/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/babel-preset"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/babel-preset/dist"],
      "options": {
        "cwd": "packages/babel-preset",
        "commands": ["tsc --build tsconfig.build.json --pretty"],
        "parallel": false
      }
    }
  }
}
