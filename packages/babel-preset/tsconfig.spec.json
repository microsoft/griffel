{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "../../dist/out-tsc",
    "typeRoots": ["../../node_modules", "../../node_modules/@types", "../../typings"],
    "types": ["vitest/importMeta", "vite/client", "node", "vitest", "environment", "static-assets"]
  },
  "include": [
    "vitest.config.mts",
    "__fixtures__/**/code.ts",
    "__fixtures__/**/fixture.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.test.jsx",
    "**/*.spec.jsx",
    "**/*.d.ts"
  ]
}
