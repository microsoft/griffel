{
  "name": "@griffel/shadow-dom",
  "version": "0.2.12",
  "description": "Shadow DOM implementation of Griffel Atomic CSS-in-JS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/griffel"
  },
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@griffel/core": "^1.20.1",
    "tslib": "^2.1.0"
  }
}
