{
  "name": "@griffel/shadow-dom",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/shadow-dom/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/shadow-dom"
      }
    },
    "bundle-size": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/shadow-dom",
        "commands": [
          {
            "command": "monosize measure"
          }
        ]
      }
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 4400,
        "configDir": "packages/shadow-dom/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputDir}"],
      "options": {
        "configDir": "packages/shadow-dom/.storybook",
        "outputDir": "dist/storybook/@griffel/shadow-dom"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-cjs": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/shadow-dom/dist/cjs"],
      "options": {
        "command": "node tools/build-cjs.ts packages/shadow-dom/dist packages/shadow-dom/dist/cjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/shadow-dom/dist"],
      "options": {
        "cwd": "packages/shadow-dom",
        "command": "tsc --build tsconfig.lib.json --pretty"
      }
    }
  }
}
