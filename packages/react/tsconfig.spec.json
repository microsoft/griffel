{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "typeRoots": ["../../node_modules", "../../node_modules/@types", "../../typings"],
    "types": ["vitest/importMeta", "vite/client", "node", "vitest", "environment"],
    "jsx": "react-jsx"
  },
  "include": [
    "vitest.config.ts",
    "src/common/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
