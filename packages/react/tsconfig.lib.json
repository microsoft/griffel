{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react",
    "types": ["node", "environment"]
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.stories.tsx",
    "src/**/__fixture__/",
    "src/**/__mocks__/"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "../core/tsconfig.lib.json" }]
}
