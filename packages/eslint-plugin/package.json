{
  "name": "@griffel/eslint-plugin",
  "version": "3.0.2",
  "type": "module",
  "description": "ESLint plugin with lint rules for Griffel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/griffel"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.59.3",
    "csstype": "^3.2.3",
    "tslib": "^2.1.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "@griffel/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
