{
  "name": "@griffel/eslint-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/eslint-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/eslint-plugin"]
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/eslint-plugin/dist"],
      "options": {
        "cwd": "packages/eslint-plugin",
        "commands": ["tsc --build tsconfig.lib.json --pretty"],
        "parallel": false
      }
    }
  }
}
