{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "../../dist/packages/core",
    "tsBuildInfoFile": "../../dist/packages/core/tsconfig.lib.tsbuildinfo",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "types": ["node", "environment"]
  },
  "exclude": [
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx",
    "jest.config.ts"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "../style-types/tsconfig.lib.json" }]
}
