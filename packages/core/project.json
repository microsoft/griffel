{
  "name": "@griffel/core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/core/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/core",
        "tsConfig": "packages/core/tsconfig.lib.json",
        "skipTypeField": true,
        "packageJson": "packages/core/package.json",
        "main": "packages/core/src/index.ts",
        "assets": [
          "packages/core/README.md",
          {
            "glob": "LICENSE.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "build-cjs": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/core/lib"],
      "options": {
        "command": "node tools/build-cjs.mjs dist/packages/core/src dist/packages/core/lib"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/core"
      }
    },
    "bundle-size": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/core",
        "commands": [
          {
            "command": "monosize measure"
          }
        ]
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/core",
        "commands": [
          {
            "command": "tsc -b --pretty"
          }
        ]
      },
      "outputs": []
    }
  }
}
