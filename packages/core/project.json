{
  "name": "@griffel/core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/core/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["_build_tsc"],
      "outputs": ["{workspaceRoot}/packages/core/dist/cjs"],
      "options": {
        "command": "node tools/build-cjs.mjs packages/core/dist packages/core/dist/cjs"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/core"
      }
    },
    "bundle-size": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/core",
        "commands": [
          {
            "command": "monosize measure"
          }
        ]
      }
    },
    "_build_tsc": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/core/dist"],
      "options": {
        "cwd": "packages/core",
        "commands": ["tsc --build tsconfig.lib.json --pretty"],
        "parallel": false
      }
    }
  }
}
