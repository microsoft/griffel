    "csstype": "^3.1.3",
    "rtl-css-js": "^1.16.1",
    "stylis": "^4.2.0",
    "tslib": "^2.1.0"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "4.0.9"
  }
}
