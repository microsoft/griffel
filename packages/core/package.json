      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "dependencies": {
    "@emotion/hash": "^0.9.0",
    "@griffel/style-types": "^1.3.0",
    "csstype": "^3.1.3",
    "rtl-css-js": "^1.16.1",
    "stylis": "^4.2.0",
    "tslib": "^2.1.0"
  }
}
