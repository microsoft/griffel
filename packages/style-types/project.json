{
  "name": "@griffel/style-types",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/style-types/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/style-types"],
      "options": {
        "cwd": "packages/style-types",
        "commands": [
          "tsc -b tsconfig.lib.json --pretty",
          "tsc -b tsconfig.lib.cjs.json --pretty",
          "cp package.json ../../dist/packages/style-types/package.json",
          "cp README.md ../../dist/packages/style-types/README.md",
          "cp ../../LICENSE.md ../../dist/packages/style-types/LICENSE.md"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/packages/style-types"],
      "options": {
        "jestConfig": "packages/style-types/jest.config.ts"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/style-types",
        "commands": [
          {
            "command": "tsc -b --pretty"
          }
        ]
      },
      "outputs": []
    }
  }
}
