{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "outDir": "./out-tsc/lib",
    "rootDir": "./src",
    "types": ["chrome", "node", "environment"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "vite.config.ts",
    "vitest.setup.ts"
  ],
  "references": [
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../react/tsconfig.lib.json"
    }
  ]
}
