{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./out-tsc/spec",
    "typeRoots": ["../../node_modules", "../../node_modules/@types", "../../typings"],
    "types": ["vitest/importMeta", "vite/client", "chrome", "node", "vitest", "environment"]
  },
  "include": [
    "vite.config.ts",
    "vitest.setup.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
