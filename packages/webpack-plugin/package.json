{
  "name": "@griffel/webpack-plugin",
  "version": "4.0.6",
  "description": "Webpack plugin that performs CSS extraction for Griffel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/griffel"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@griffel/source": "./src/index.mts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./loader": {
      "@griffel/source": "./src/webpackLoader.mts",
      "types": "./dist/webpackLoader.d.mts",
      "default": "./dist/webpackLoader.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "virtual-loader/",
    "dist/",
    "README.md",
    "LICENSE.md"
  ],
  "dependencies": {
    "@griffel/core": "^1.21.2",
    "@griffel/transform": "^3.0.6",
    "oxc-resolver": "^11.19.1",
    "stylis": "^4.4.0"
  },
  "peerDependencies": {
    "webpack": "^5"
  }
}
