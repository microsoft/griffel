{
  "name": "@griffel/webpack-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/webpack-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/webpack-plugin/dist"],
      "options": {
        "cwd": "packages/webpack-plugin",
        "commands": [
          "tsc --build tsconfig.lib.json --pretty",
          "node ../../tools/copy-pkg-assets.mjs packages/webpack-plugin"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/webpack-plugin"
      }
    }
  }
}
