{
  "name": "@griffel/sort-css-queries",
  "version": "1.0.1",
  "description": "Comparator for ordering CSS query conditions (@media / @container) numerically in Griffel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/griffel"
  },
  "dependencies": {
    "tslib": "^2.1.0"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  }
