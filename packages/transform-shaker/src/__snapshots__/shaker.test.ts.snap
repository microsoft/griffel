// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`does not break export * as ns when requesting the namespace export 1`] = `"export * as ns from './module';"`;

exports[`keeps ESM default import with batch export 1`] = `
"import blank from './blank.jpg';
export const __mkPreval = { backgroundImage: blank };"
`;

exports[`keeps ESM import with batch export 1`] = `
"import { colorBlue } from './consts';
export const __mkPreval = { color: colorBlue };"
`;

exports[`keeps IIFE enum initializer when export is requested 1`] = `
"export var ThemeName;
(function (ThemeName) {
    ThemeName[ThemeName["Light"] = 0] = "Light";
    ThemeName[ThemeName["Dark"] = 1] = "Dark";
})(ThemeName || (ThemeName = {}));"
`;

exports[`keeps all export-all re-exports when requested export is not found locally 1`] = `
"export * from './foo';
export * from './baz';"
`;

exports[`keeps class with constructor references to imports and sibling exports 1`] = `
"import { baseHeight } from './base';
import { labels } from './labels';

export const defaults = {
    transparent: 'transparent'
};

export class Config {
    constructor(){
        this.height = baseHeight;
        this.color = labels.highlight;
        this.fallback = defaults.transparent;
    }
}

export const config = new Config();"
`;

exports[`keeps export const declarators 1`] = `"export const colorBlue = 'blue';"`;

exports[`keeps export default identifier referencing a function declaration 1`] = `
"function isPlainObject(value) {
  return typeof value === 'object';
}
export default isPlainObject;"
`;

exports[`keeps export-all re-exports when referenced export is not found locally 1`] = `
"export * from './colors';
"
`;

exports[`keeps for-of loop right-hand side reference 1`] = `
"export function fn(obj) {
  const result = {};
  const keys = Object.keys(obj);
  for (const key of keys) {
    result[key] = obj[key];
  }
  return result;
}"
`;

exports[`keeps identifiers inside template literals 1`] = `
"const color = 'red';
const result = \`color is \${color}\`;
export const __linariaPreval = [result];"
`;

exports[`keeps identifiers used as computed property keys 1`] = `
"const selector = '& .foo';
const styles = { [selector]: { color: 'red' } };
export const __linariaPreval = [styles];"
`;

exports[`keeps identifiers used as spread arguments 1`] = `
"const shared = { display: 'flex' };
const styles = { ...shared, color: 'red' };
export const __linariaPreval = [styles];"
`;

exports[`keeps local export specifiers (export { name }) 1`] = `
"import { border } from './shorthands/border';
import { margin } from './shorthands/margin';

const shorthands = {
  border,
  margin,
};

export { shorthands };"
`;

exports[`keeps multiple export const declarators 1`] = `
"export const className = 'component-foo';
export const selector = '& .component-bar';"
`;

exports[`keeps objects as is 1`] = `
"const fill1 = (top = 0, left = 0, right = 0, bottom = 0) => ({
  position: 'absolute',
  top,
  right,
  bottom,
  left,
});

const fill2 = (top = 0, left = 0, right = 0, bottom = 0) => {
  return {
    position: 'absolute',
    top,
    right,
    bottom,
    left,
  };
};

export const __linariaPreval = [fill1, fill2];"
`;

exports[`keeps only code which is related to \`a\` 1`] = `
"import { whiteColor as color, anotherColor } from '…';
const a = color || anotherColor;
color.green = '#0f0';
export const __linariaPreval = [a];"
`;

exports[`keeps only code which is related to \`anotherColor\` 1`] = `
"import { anotherColor } from '…';
export const __linariaPreval = [anotherColor];"
`;

exports[`keeps only code which is related to \`color\` 1`] = `
"import { whiteColor as color } from '…';
color.green = '#0f0';
export const __linariaPreval = [color];"
`;

exports[`keeps only referenced re-exports from barrel files 1`] = `
"export { colorBlue, colorGreen } from './colors';
"
`;

exports[`keeps reused exports 1`] = `
"export const bar = function() {
  return 'hello world';
};

const foo = bar();
export const __linariaPreval = [foo];"
`;

exports[`preserves catch clause parameter when unused 1`] = `
"function fn() {
  try { throw new Error('test'); }
  catch (e) { /* unused */ }
}
export const __linariaPreval = [fn];"
`;

exports[`preserves labeled statement label 1`] = `
"function fn() {
  var result = [];
  outer:
  while (true) {
    result.push(1);
    break ;
  }
  return result;
}
export const __linariaPreval = [fn];"
`;

exports[`removes \`export * as ns\` if not requested 1`] = `"export * from './other';"`;

exports[`removes all 1`] = `
"
export const __linariaPreval = [];"
`;

exports[`shakes assignment patterns 1`] = `
"const [identifier = 1] = [2];
const [{...object} = {}] = [{ a: 1, b: 2 }];
const [[...array] = []] = [[1,2,3,4]];
const obj = { member: null };
export const __linariaPreval = [identifier, object, array, obj];"
`;

exports[`shakes es5 exports 1`] = `
"export const redColor = 'red';
export const yellowColor = 'yellow';
export const greenColor = (() => 'green')();"
`;

exports[`shakes export-all when requested export is found as named re-export 1`] = `"export { baz } from './baz';"`;

exports[`shakes exports 1`] = `
"import { whiteColor as color } from '…';
export const a = color;
export const __linariaPreval = [a];"
`;

exports[`shakes for-in statements 1`] = `
"const obj1 = { a: 1, b: 2 };
const obj2 = {};
for (const key in obj1) {
  obj2[key] = obj1[key];
}
export const __linariaPreval = [obj2];"
`;

exports[`shakes imports 1`] = `
"import { whiteColor as color } from '…';
import defaultColor from '…';
export const __linariaPreval = [color, defaultColor];"
`;

exports[`shakes sequence expression 1`] = `
"const color1 = (() => 'blue');
let local = '';
const color2 = (local = color1(), () => local);
export const __linariaPreval = [color2];"
`;

exports[`shakes unrelated IIFE enums in the same file 1`] = `
"export var ThemeName;
(function (ThemeName) {
    ThemeName[ThemeName["Light"] = 0] = "Light";
    ThemeName[ThemeName["Dark"] = 1] = "Dark";
})(ThemeName || (ThemeName = {}));"
`;

exports[`should keep member expression key 1`] = `
"const key = 'blue';
const obj = { blue: '#00F' };
const blue = obj[key];
export const __linariaPreval = [blue];"
`;
