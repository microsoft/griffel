{
  "name": "@griffel/e2e-eslint",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "e2e/eslint/src",
  "projectType": "library",
  "implicitDependencies": ["@griffel/eslint-plugin"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        }
      ],
      "options": {
        "cwd": "e2e/eslint",
        "commands": [
          {
            "command": "node src/test.ts"
          }
        ]
      },
      "outputs": []
    }
  },
  "tags": []
}
