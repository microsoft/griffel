{
  "name": "@griffel/e2e-rspack",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "e2e/rspack/src",
  "projectType": "library",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "target": "build",
          "dependencies": true
        },
        {
          "target": "build-cjs",
          "dependencies": true
        }
      ],
      "options": {
        "cwd": "e2e/rspack",
        "commands": [
          {
            "command": "node src/test.ts"
          }
        ]
      },
      "outputs": []
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  },
  "tags": []
}
