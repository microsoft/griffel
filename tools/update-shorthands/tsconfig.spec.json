{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "noEmit": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": ["jest", "node", "environment"]
  },
  "include": [
    "__fixtures__/*/code.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "**/*.test.js",
    "**/*.spec.js",
    "**/*.test.jsx",
    "**/*.spec.jsx",
    "**/*.d.ts",
    "jest.config.ts"
  ]
}
