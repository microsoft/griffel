{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "extends": "nx/presets/core.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build", "^build-cjs"],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "build-storybook": {
      "cache": true
    },
    "type-check": {
      "cache": true
    },
    "@nx/eslint:lint": {
      "inputs": ["default", "^default", "{workspaceRoot}/eslint.config.mjs", "{workspaceRoot}/tools/eslint-rules/**/*"],
      "cache": true
    },
    "@nx/vite:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    },
    "@nx/vitest:test": {
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "build-cjs": {
      "dependsOn": ["build", "^build-cjs"],
      "cache": true
    }
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "type-check"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json"
        }
      }
    }
  ],
  "pluginsConfig": {
    "@nx/js": {
      "analyzeSourceFiles": true
    }
  },
  "useInferencePlugins": true,
  "sync": {
    "applyChanges": true
  },
  "defaultBase": "main",
  "tui": {
    "enabled": false
  },
  "generators": {
    "@nx/react": {
      "library": {
        "unitTestRunner": "none"
      }
    }
  },
  "analytics": false
}
